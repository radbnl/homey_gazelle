{
  "name": {
    "en": "Gazelle E-Bike",
    "nl": "Gazelle E-Bike"
  },
  "class": "other",
  "energy": {
    "batteries": ["OTHER"]
  },
  "capabilities": [
    "measure_battery",
    "alarm_battery",
    "meter_range",
    "meter_odometer",
    "charging_state",
    "assist_level",
    "location_latitude",
    "location_longitude"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
